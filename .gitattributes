# Auto-detect text files and normalize line endings
* text=auto

# Shell scripts must stay LF
*.sh text eol=lf

# PowerShell scripts — LF is conventional in git even on Windows
*.ps1 text eol=lf

# Makefile
Makefile text eol=lf

# Source code
*.cpp text eol=lf
*.hpp text eol=lf
*.h text eol=lf
*.c text eol=lf

# Config / data files
*.conf text eol=lf
*.wdl text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.cfg text eol=lf

# Binary files — do not touch
*.png binary
*.jpg binary
*.jpeg binary
*.mp3 binary
*.wav binary
*.ogg binary
*.obj binary
*.sav binary
*.dll binary
*.exe binary
*.so binary
