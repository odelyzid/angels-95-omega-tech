entity "selenite_blade" : weapon {
    mesh = "selenite_blade_lvl1.obj"
    texture = "selenite_blade_lvl1_texture.png"
    icon = "selenite_blade_icon.png"
    stats {
        damage = 40
        swing_speed = 0.8
        reach = 3.0
        stamina_cost = 15
    }
    actions {
        on_swing {
            say "Slash! (40 damage)"
            set_cooldown 0.8
        }
        on_hit {
            say "Blade connects!"
        }
    }
}
