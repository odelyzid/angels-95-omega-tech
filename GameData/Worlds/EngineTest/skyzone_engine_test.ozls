entity "zone_sky_0" : skyzone {
    fog_color = (0.6, 0.65, 0.75)
    fog_density = 0.004
    ambient_light = (0.6, 0.55, 0.5)
    skybox = "GameData/Worlds/EngineTest/Models/Skybox.png"
    actions {
        on_enter {
            set_fog 0.6 0.65 0.75 0.004
            set_ambient 0.6 0.55 0.5
            set_skybox "GameData/Worlds/EngineTest/Models/Skybox.png"
            say "Entered EngineTest — ambient/fog/skybox active"
        }
        on_exit {
            restore_fog
            restore_skybox
            say "Exited EngineTest sky zone"
        }
    }
}
